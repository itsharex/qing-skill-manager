{
  "name": "qing-skill-manager",
  "private": true,
  "version": "0.3.26",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "check:project": "node \"scripts/check-project.js\"",
    "release": "node \"scripts/release.js\"",
    "test": "npm run test:frontend && npm run test:rust",
    "test:frontend": "npm run test:frontend:logic && npm run typecheck && npm run build:verify",
    "test:frontend:logic": "node --experimental-strip-types \"src/composables/constants.test.mjs\" && node --experimental-strip-types \"src/composables/useLibraryWorkspace.test.mjs\"",
    "test:rust": "cd src-tauri && cargo test",
    "typecheck": "vue-tsc --noEmit",
    "build:verify": "vite build --mode production",
    "check": "npm run check:frontend && npm run check:rust",
    "check:frontend": "npm run typecheck",
    "check:rust": "cd src-tauri && cargo check && cargo clippy -- -D warnings",
    "check:rust:fix": "cd src-tauri && cargo clippy --fix --allow-dirty",
    "verify": "npm run check && npm run test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
