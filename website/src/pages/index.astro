---
import BaseLayout from '@layouts/BaseLayout.astro'
import ThemeToggle from '@components/ThemeToggle.astro'
import LanguageSwitch from '@components/LanguageSwitch.astro'

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<BaseLayout
  title="Qing Skill Manager — Multi-IDE AI Skill Hub"
  description="Discover, manage, and distribute AI skills across Claude Code, Cursor, Codex, OpenCode and more. One desktop app, all your IDEs."
  lang="en"
>
  <!-- ========== NAV ========== -->
  <nav class="sticky top-0 z-50 backdrop-blur-xl bg-background/70 border-b border-border/50">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href={`${BASE}/`} class="flex items-center gap-2 font-semibold text-lg tracking-tight">
        <img src={`${BASE}/favicon-32x32.png`} alt="" class="w-6 h-6 rounded" />
        Qing Skill Manager
      </a>
      <div class="flex items-center gap-2">
        <a href="#features" class="hidden sm:inline-block px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">Features</a>
        <a href="#screenshots" class="hidden sm:inline-block px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">Screenshots</a>
        <a href="#quickstart" class="hidden sm:inline-block px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">Quick Start</a>
        <LanguageSwitch lang="en" />
        <ThemeToggle />
      </div>
    </div>
  </nav>

  <main class="relative z-10">
    <!-- ========== HERO ========== -->
    <section class="pt-20 pb-16 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent text-foreground text-sm font-medium mb-8 border border-border">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          v0.3.22 &mdash; Open Source
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-6">
          Every project. Every IDE.<br />
          <span class="bg-gradient-to-r from-foreground via-chart-3 to-muted-foreground bg-clip-text text-transparent">All your AI Skills in one place.</span>
        </h1>
        <p class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-10 leading-relaxed">
          Skills scattered across Cursor, Claude Code, OpenCode, and a dozen project folders? Qing Skill Manager gives you a unified library with multi-version tracking, per-project deployment, and cross-IDE sync &mdash; so you always know what's installed where.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
          <a
            href="https://github.com/qing-claw/qing-skill-manager"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity shadow-lg shadow-primary/10"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
          <a
            href="#quickstart"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-secondary text-secondary-foreground font-semibold hover:bg-secondary/80 transition-colors border border-border"
          >
            Get Started
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>

        <!-- Hero screenshot -->
        <div class="relative mx-auto max-w-5xl">
          <div class="absolute -inset-4 bg-gradient-to-r from-muted-foreground/10 via-accent/30 to-muted-foreground/10 rounded-2xl blur-2xl opacity-50"></div>
          <img
            src={`${BASE}/screenshots/local.jpg`}
            alt="Qing Skill Manager — Skill Library"
            class="relative rounded-xl border border-border/50 shadow-2xl w-full"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- ========== IDE STRIP ========== -->
    <section class="py-12 px-6 border-y border-border/30">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm text-muted-foreground mb-6 uppercase tracking-widest font-medium">Natively supports</p>
        <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-foreground/70 font-medium text-base">
          <span>Claude Code</span>
          <span class="text-border">|</span>
          <span>Cursor</span>
          <span class="text-border">|</span>
          <span>Codex</span>
          <span class="text-border">|</span>
          <span>OpenCode</span>
          <span class="text-border">|</span>
          <span>OpenClaw</span>
          <span class="text-border">|</span>
          <span class="text-foreground font-semibold">+ Custom IDEs</span>
        </div>
      </div>
    </section>

    <!-- ========== FEATURES ========== -->
    <section id="features" class="py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">One tool to rule them all</h2>
          <p class="text-muted-foreground text-lg max-w-2xl mx-auto">Manage skills across Agent IDEs and projects on your device &mdash; with version control, classification, and conflict resolution.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4 text-xl">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Multi-IDE Management</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">Claude Code, Cursor, Codex, OpenCode, OpenClaw &mdash; each has its own skills directory. See them all in one view, install or sync across IDEs, or add any custom IDE in seconds.</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Multi-Version Tracking</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">Every skill can have multiple versions. Compare diffs side-by-side, set defaults, create named variants for different use cases, and pin specific versions to specific projects.</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Skill Classification</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">Skills are classified as Managed, Unmanaged, or Plugin-Only. Filter by IDE platform, status, or name. Three-column library workspace with sidebar, detail panel, and version rail.</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Per-Project Deployment</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">Register projects, configure IDE targets, deploy specific versions. Auto-detects existing project skills and resolves conflicts with keep, overwrite, or coexist options.</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Marketplace Discovery</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">Search Claude Plugins, SkillsLLM, and SkillsMP in one interface. Download or update with one click. Skills land in your local repo, ready to deploy anywhere.</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">Conflict Resolution</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">When a project skill diverges from your repo version, the app detects it automatically. Analyze diffs, get resolution suggestions, then choose how to reconcile.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== SCREENSHOTS ========== -->
    <section id="screenshots" class="py-20 px-6 bg-muted/30">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">See it in action</h2>
          <p class="text-muted-foreground text-lg">Four main workspaces covering the full skill lifecycle.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <div class="rounded-xl overflow-hidden border border-border/50 shadow-lg mb-3 bg-card">
              <img src={`${BASE}/screenshots/local.jpg`} alt="Local Skills" class="w-full" loading="lazy" />
            </div>
            <h3 class="font-semibold text-center">Local Skills</h3>
            <p class="text-sm text-muted-foreground text-center">Browse and manage your entire skill collection</p>
          </div>
          <div>
            <div class="rounded-xl overflow-hidden border border-border/50 shadow-lg mb-3 bg-card">
              <img src={`${BASE}/screenshots/market.jpg`} alt="Marketplace" class="w-full" loading="lazy" />
            </div>
            <h3 class="font-semibold text-center">Marketplace</h3>
            <p class="text-sm text-muted-foreground text-center">Search and download from multiple registries</p>
          </div>
          <div>
            <div class="rounded-xl overflow-hidden border border-border/50 shadow-lg mb-3 bg-card">
              <img src={`${BASE}/screenshots/ide.jpg`} alt="IDE Browser" class="w-full" loading="lazy" />
            </div>
            <h3 class="font-semibold text-center">IDE Browser</h3>
            <p class="text-sm text-muted-foreground text-center">View and manage per-IDE installations</p>
          </div>
          <div>
            <div class="rounded-xl overflow-hidden border border-border/50 shadow-lg mb-3 bg-card">
              <img src={`${BASE}/screenshots/project.jpg`} alt="Projects" class="w-full" loading="lazy" />
            </div>
            <h3 class="font-semibold text-center">Projects</h3>
            <p class="text-sm text-muted-foreground text-center">Configure IDE targets and deploy skills per project</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== WORKFLOW ========== -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">How it works</h2>
          <p class="text-muted-foreground text-lg">Five steps from discovery to deployment.</p>
        </div>
        <div class="space-y-0">
          {[
            { step: '1', title: 'Search', desc: 'Find skills from Claude Plugins, SkillsLLM, or SkillsMP in the Market tab.' },
            { step: '2', title: 'Download', desc: 'One click adds the skill to your local repository. Updates are detected automatically.' },
            { step: '3', title: 'Install', desc: 'Pick one or more IDEs and install globally, or clone into a specific project.' },
            { step: '4', title: 'Manage', desc: 'Track versions, compare diffs, create variants, and set defaults.' },
            { step: '5', title: 'Resolve', desc: 'When project skills conflict with your repo, choose to keep, overwrite, or coexist.' },
          ].map(({ step, title, desc }) => (
            <div class="flex gap-6 items-start group">
              <div class="flex flex-col items-center">
                <div class="w-10 h-10 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold text-sm shrink-0 shadow-md shadow-primary/10">
                  {step}
                </div>
                {step !== '5' && <div class="w-px h-12 bg-border group-hover:bg-primary/30 transition-colors" />}
              </div>
              <div class="pb-12">
                <h3 class="font-semibold text-lg mb-1">{title}</h3>
                <p class="text-muted-foreground">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== IDE TABLE ========== -->
    <section class="py-20 px-6 bg-muted/30">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Supported IDEs</h2>
          <p class="text-muted-foreground text-lg">Works out of the box with these IDEs, plus any custom one you register.</p>
        </div>
        <div class="overflow-hidden rounded-xl border border-border/50 bg-card/50 backdrop-blur-sm">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border/50 bg-muted/50">
                <th class="text-left px-6 py-3 font-semibold">IDE</th>
                <th class="text-left px-6 py-3 font-semibold">Global Path</th>
                <th class="text-left px-6 py-3 font-semibold">Project Path</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border/30">
              {[
                ['Claude Code', '~/.claude/skills', '.claude/skills'],
                ['Codex', '~/.codex/skills', '.codex/skills'],
                ['Cursor', '~/.cursor/skills', '.cursor/skills'],
                ['OpenClaw', '~/.openclaw/skills', '.openclaw/skills'],
                ['OpenCode', '~/.config/opencode/skills', '.opencode/skills'],
              ].map(([name, global_path, project]) => (
                <tr class="hover:bg-muted/30 transition-colors">
                  <td class="px-6 py-3 font-medium">{name}</td>
                  <td class="px-6 py-3 font-mono text-xs text-muted-foreground">{global_path}</td>
                  <td class="px-6 py-3 font-mono text-xs text-muted-foreground">{project}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ========== QUICK START ========== -->
    <section id="quickstart" class="py-20 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Quick Start</h2>
          <p class="text-muted-foreground text-lg">Build from source in three commands.</p>
        </div>

        <div class="space-y-6">
          <div>
            <h3 class="font-semibold mb-3">Prerequisites</h3>
            <div class="flex flex-wrap gap-3 text-sm">
              <span class="px-3 py-1 rounded-full bg-secondary border border-border/50">Node.js (LTS)</span>
              <span class="px-3 py-1 rounded-full bg-secondary border border-border/50">Rust (rustup)</span>
              <span class="px-3 py-1 rounded-full bg-secondary border border-border/50">pnpm</span>
            </div>
          </div>

          <div class="rounded-xl bg-[#1e1e2e] text-[#cdd6f4] p-6 font-mono text-sm leading-relaxed overflow-x-auto shadow-xl">
            <div class="flex items-center gap-2 mb-4 text-[#6c7086]">
              <span class="w-3 h-3 rounded-full bg-[#f38ba8]"></span>
              <span class="w-3 h-3 rounded-full bg-[#a6e3a1]"></span>
              <span class="w-3 h-3 rounded-full bg-[#f9e2af]"></span>
              <span class="ml-2 text-xs">Terminal</span>
            </div>
            <pre class="whitespace-pre"><code><span class="text-[#a6e3a1]">$</span> git clone https://github.com/qing-claw/qing-skill-manager.git
<span class="text-[#a6e3a1]">$</span> cd qing-skill-manager/skills-manager
<span class="text-[#a6e3a1]">$</span> pnpm install
<span class="text-[#a6e3a1]">$</span> pnpm tauri dev     <span class="text-[#6c7086]"># launch dev environment</span>

<span class="text-[#a6e3a1]">$</span> pnpm tauri build   <span class="text-[#6c7086]"># build desktop app</span></code></pre>
          </div>

          <div class="p-4 rounded-xl bg-accent/30 border border-accent/50 text-sm">
            <p class="font-semibold mb-1">macOS Note</p>
            <p class="text-muted-foreground">First launch may show a security warning. Run <code class="bg-muted px-1.5 py-0.5 rounded text-xs">xattr -dr com.apple.quarantine "/Applications/qing-skill-manager.app"</code> to bypass it.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== TECH STACK ========== -->
    <section class="py-20 px-6 bg-muted/30">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Tech Stack</h2>
        </div>
        <div class="grid sm:grid-cols-3 gap-6 text-center">
          <div class="p-6 rounded-xl bg-card/50 border border-border/50 backdrop-blur-sm">
            <div class="text-2xl mb-2 font-bold text-foreground">Tauri 2</div>
            <p class="text-sm text-muted-foreground">Rust-powered desktop runtime with native performance and tiny bundle size</p>
          </div>
          <div class="p-6 rounded-xl bg-card/50 border border-border/50 backdrop-blur-sm">
            <div class="text-2xl mb-2 font-bold text-foreground">Vue 3</div>
            <p class="text-sm text-muted-foreground">TypeScript + Vite frontend with Composition API and reactive composables</p>
          </div>
          <div class="p-6 rounded-xl bg-card/50 border border-border/50 backdrop-blur-sm">
            <div class="text-2xl mb-2 font-bold text-foreground">Rust</div>
            <p class="text-sm text-muted-foreground">Backend commands for filesystem operations, downloads, and version tracking</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== FOOTER ========== -->
    <footer class="py-12 px-6 border-t border-border/30">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm text-muted-foreground mb-4">
          Built on top of <a href="https://github.com/Rito-w/skills-manager" target="_blank" rel="noopener" class="text-foreground font-medium hover:underline">skills-manager</a> by Rito-w. Thanks to all contributors.
        </p>
        <div class="flex items-center justify-center gap-6 text-sm text-muted-foreground">
          <a href="https://github.com/qing-claw/qing-skill-manager" target="_blank" rel="noopener" class="hover:text-foreground transition-colors">GitHub</a>
          <span class="text-border">|</span>
          <span>MIT License</span>
          <span class="text-border">|</span>
          <a href="https://github.com/qing-claw/qing-skill-manager/releases" target="_blank" rel="noopener" class="hover:text-foreground transition-colors">Releases</a>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
