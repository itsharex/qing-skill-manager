---
import BaseLayout from '@layouts/BaseLayout.astro'
import ThemeToggle from '@components/ThemeToggle.astro'
import LanguageSwitch from '@components/LanguageSwitch.astro'

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<BaseLayout
  title="Qing Skill Manager — 多 IDE AI 技能管理中心"
  description="发现、管理和分发 AI Skills 到 Claude Code、Cursor、Codex、OpenCode 等多个 IDE。一个桌面应用，管理所有 IDE。"
  lang="zh"
>
  <!-- ========== NAV ========== -->
  <nav class="sticky top-0 z-50 backdrop-blur-xl bg-background/70 border-b border-border/50">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href={`${BASE}/zh/`} class="font-semibold text-lg tracking-tight">Qing Skill Manager</a>
      <div class="flex items-center gap-2">
        <a href="#features" class="hidden sm:inline-block px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">功能</a>
        <a href="#screenshots" class="hidden sm:inline-block px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">截图</a>
        <a href="#quickstart" class="hidden sm:inline-block px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">快速开始</a>
        <LanguageSwitch lang="zh" />
        <ThemeToggle />
      </div>
    </div>
  </nav>

  <main class="relative z-10">
    <!-- ========== HERO ========== -->
    <section class="pt-20 pb-16 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent text-foreground text-sm font-medium mb-8 border border-border">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          v0.3.22 &mdash; 开源项目
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-6">
          一个应用管理所有<br />
          <span class="bg-gradient-to-r from-foreground via-chart-3 to-muted-foreground bg-clip-text text-transparent">AI 技能</span>
        </h1>
        <p class="text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto mb-10 leading-relaxed">
          搜索公共市场、统一存入本地仓库、一键安装到任意 IDE、将带版本控制的副本部署到项目中 &mdash; 内建冲突检测与解决机制。
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
          <a
            href="https://github.com/qing-claw/qing-skill-manager"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity shadow-lg shadow-primary/10"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            在 GitHub 上查看
          </a>
          <a
            href="#quickstart"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-secondary text-secondary-foreground font-semibold hover:bg-secondary/80 transition-colors border border-border"
          >
            快速开始
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
        </div>

        <!-- Hero screenshot -->
        <div class="relative mx-auto max-w-5xl">
          <div class="absolute -inset-4 bg-gradient-to-r from-muted-foreground/10 via-accent/30 to-muted-foreground/10 rounded-2xl blur-2xl opacity-50"></div>
          <img
            src={`${BASE}/screenshots/zh-CN/market.jpg`}
            alt="Qing Skill Manager — 商店检索"
            class="relative rounded-xl border border-border/50 shadow-2xl w-full"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- ========== IDE STRIP ========== -->
    <section class="py-12 px-6 border-y border-border/30">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm text-muted-foreground mb-6 uppercase tracking-widest font-medium">原生支持</p>
        <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-foreground/70 font-medium text-base">
          <span>Claude Code</span>
          <span class="text-border">|</span>
          <span>Cursor</span>
          <span class="text-border">|</span>
          <span>Codex</span>
          <span class="text-border">|</span>
          <span>OpenCode</span>
          <span class="text-border">|</span>
          <span>OpenClaw</span>
          <span class="text-border">|</span>
          <span class="text-foreground font-semibold">+ 自定义 IDE</span>
        </div>
      </div>
    </section>

    <!-- ========== FEATURES ========== -->
    <section id="features" class="py-20 px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">你需要的一切</h2>
          <p class="text-muted-foreground text-lg max-w-2xl mx-auto">一套完整的工具，用于发现、版本管理和部署 AI 技能到你的整个开发环境。</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4 text-xl">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">聚合市场检索</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">在一个界面中搜索 Claude Plugins、SkillsLLM 和 SkillsMP 的技能。一键下载或更新。</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">统一本地仓库</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">所有技能集中存储在 <code class="text-xs bg-muted px-1.5 py-0.5 rounded">~/.qing-skill-manager/skills</code>。浏览、筛选和管理你的全部收藏。</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">一键安装</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">同时安装到多个 IDE。支持全局安装和项目级克隆，精确控制作用范围。</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">版本管理</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">Git 风格版本跟踪。对比版本差异、设置默认版本、创建变体，并为项目锁定指定版本。</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">项目管理</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">注册项目、配置 IDE 目标、直接部署技能。自动检测已有技能并解决版本冲突。</p>
          </div>

          <div class="group p-6 rounded-xl bg-card/50 border border-border/50 hover:border-muted-foreground/30 hover:shadow-lg transition-all backdrop-blur-sm">
            <div class="w-10 h-10 rounded-lg bg-accent text-foreground flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
            </div>
            <h3 class="font-semibold text-lg mb-2">IDE 浏览器</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">切换 IDE 视图查看安装情况。将未托管的技能纳入仓库统一管理，或添加任意自定义 IDE。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== SCREENSHOTS ========== -->
    <section id="screenshots" class="py-20 px-6 bg-muted/30">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">界面预览</h2>
          <p class="text-muted-foreground text-lg">四个主要工作区，覆盖完整的技能生命周期。</p>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <div class="rounded-xl overflow-hidden border border-border/50 shadow-lg mb-3 bg-card">
              <img src={`${BASE}/screenshots/zh-CN/local.jpg`} alt="本地技能库" class="w-full" loading="lazy" />
            </div>
            <h3 class="font-semibold text-center">本地技能库</h3>
            <p class="text-sm text-muted-foreground text-center">浏览和管理你的全部技能收藏</p>
          </div>
          <div>
            <div class="rounded-xl overflow-hidden border border-border/50 shadow-lg mb-3 bg-card">
              <img src={`${BASE}/screenshots/zh-CN/market.jpg`} alt="商店检索" class="w-full" loading="lazy" />
            </div>
            <h3 class="font-semibold text-center">商店检索</h3>
            <p class="text-sm text-muted-foreground text-center">从多个注册中心搜索和下载</p>
          </div>
          <div>
            <div class="rounded-xl overflow-hidden border border-border/50 shadow-lg mb-3 bg-card">
              <img src={`${BASE}/screenshots/zh-CN/ide.jpg`} alt="IDE 浏览" class="w-full" loading="lazy" />
            </div>
            <h3 class="font-semibold text-center">IDE 浏览</h3>
            <p class="text-sm text-muted-foreground text-center">查看和管理各 IDE 的安装情况</p>
          </div>
          <div>
            <div class="rounded-xl overflow-hidden border border-border/50 shadow-lg mb-3 bg-card">
              <img src={`${BASE}/screenshots/zh-CN/project.jpg`} alt="项目管理" class="w-full" loading="lazy" />
            </div>
            <h3 class="font-semibold text-center">项目管理</h3>
            <p class="text-sm text-muted-foreground text-center">配置 IDE 目标，按项目部署技能</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== WORKFLOW ========== -->
    <section class="py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">工作流程</h2>
          <p class="text-muted-foreground text-lg">从发现到部署，只需五步。</p>
        </div>
        <div class="space-y-0">
          {[
            { step: '1', title: '搜索', desc: '在 Market 标签页中搜索来自 Claude Plugins、SkillsLLM 或 SkillsMP 的技能。' },
            { step: '2', title: '下载', desc: '一键将技能添加到本地仓库。已有版本的更新会被自动检测。' },
            { step: '3', title: '安装', desc: '选择一个或多个 IDE 进行全局安装，或克隆到特定项目。' },
            { step: '4', title: '管理', desc: '跟踪版本、对比差异、创建变体、设置默认版本。' },
            { step: '5', title: '解决冲突', desc: '当项目技能与仓库版本不一致时，可选择保留、覆盖或共存。' },
          ].map(({ step, title, desc }) => (
            <div class="flex gap-6 items-start group">
              <div class="flex flex-col items-center">
                <div class="w-10 h-10 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold text-sm shrink-0 shadow-md shadow-primary/10">
                  {step}
                </div>
                {step !== '5' && <div class="w-px h-12 bg-border group-hover:bg-primary/30 transition-colors" />}
              </div>
              <div class="pb-12">
                <h3 class="font-semibold text-lg mb-1">{title}</h3>
                <p class="text-muted-foreground">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== IDE TABLE ========== -->
    <section class="py-20 px-6 bg-muted/30">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">支持的 IDE</h2>
          <p class="text-muted-foreground text-lg">开箱即用支持以下 IDE，还可以注册任意自定义 IDE。</p>
        </div>
        <div class="overflow-hidden rounded-xl border border-border/50 bg-card/50 backdrop-blur-sm">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border/50 bg-muted/50">
                <th class="text-left px-6 py-3 font-semibold">IDE</th>
                <th class="text-left px-6 py-3 font-semibold">全局路径</th>
                <th class="text-left px-6 py-3 font-semibold">项目路径</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border/30">
              {[
                ['Claude Code', '~/.claude/skills', '.claude/skills'],
                ['Codex', '~/.codex/skills', '.codex/skills'],
                ['Cursor', '~/.cursor/skills', '.cursor/skills'],
                ['OpenClaw', '~/.openclaw/skills', '.openclaw/skills'],
                ['OpenCode', '~/.config/opencode/skills', '.opencode/skills'],
              ].map(([name, global_path, project]) => (
                <tr class="hover:bg-muted/30 transition-colors">
                  <td class="px-6 py-3 font-medium">{name}</td>
                  <td class="px-6 py-3 font-mono text-xs text-muted-foreground">{global_path}</td>
                  <td class="px-6 py-3 font-mono text-xs text-muted-foreground">{project}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ========== QUICK START ========== -->
    <section id="quickstart" class="py-20 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">快速开始</h2>
          <p class="text-muted-foreground text-lg">三条命令即可从源码构建。</p>
        </div>

        <div class="space-y-6">
          <div>
            <h3 class="font-semibold mb-3">环境要求</h3>
            <div class="flex flex-wrap gap-3 text-sm">
              <span class="px-3 py-1 rounded-full bg-secondary border border-border/50">Node.js (LTS)</span>
              <span class="px-3 py-1 rounded-full bg-secondary border border-border/50">Rust (rustup)</span>
              <span class="px-3 py-1 rounded-full bg-secondary border border-border/50">pnpm</span>
            </div>
          </div>

          <div class="rounded-xl bg-[#1e1e2e] text-[#cdd6f4] p-6 font-mono text-sm leading-relaxed overflow-x-auto shadow-xl">
            <div class="flex items-center gap-2 mb-4 text-[#6c7086]">
              <span class="w-3 h-3 rounded-full bg-[#f38ba8]"></span>
              <span class="w-3 h-3 rounded-full bg-[#a6e3a1]"></span>
              <span class="w-3 h-3 rounded-full bg-[#f9e2af]"></span>
              <span class="ml-2 text-xs">Terminal</span>
            </div>
            <pre class="whitespace-pre"><code><span class="text-[#a6e3a1]">$</span> git clone https://github.com/qing-claw/qing-skill-manager.git
<span class="text-[#a6e3a1]">$</span> cd qing-skill-manager/skills-manager
<span class="text-[#a6e3a1]">$</span> pnpm install
<span class="text-[#a6e3a1]">$</span> pnpm tauri dev     <span class="text-[#6c7086]"># 启动开发环境</span>

<span class="text-[#a6e3a1]">$</span> pnpm tauri build   <span class="text-[#6c7086]"># 构建桌面应用</span></code></pre>
          </div>

          <div class="p-4 rounded-xl bg-accent/30 border border-accent/50 text-sm">
            <p class="font-semibold mb-1">macOS 提示</p>
            <p class="text-muted-foreground">首次启动可能出现安全警告。执行 <code class="bg-muted px-1.5 py-0.5 rounded text-xs">xattr -dr com.apple.quarantine "/Applications/qing-skill-manager.app"</code> 即可放行。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== TECH STACK ========== -->
    <section class="py-20 px-6 bg-muted/30">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">技术栈</h2>
        </div>
        <div class="grid sm:grid-cols-3 gap-6 text-center">
          <div class="p-6 rounded-xl bg-card/50 border border-border/50 backdrop-blur-sm">
            <div class="text-2xl mb-2 font-bold text-foreground">Tauri 2</div>
            <p class="text-sm text-muted-foreground">Rust 驱动的桌面运行时，原生性能与极小体积</p>
          </div>
          <div class="p-6 rounded-xl bg-card/50 border border-border/50 backdrop-blur-sm">
            <div class="text-2xl mb-2 font-bold text-foreground">Vue 3</div>
            <p class="text-sm text-muted-foreground">TypeScript + Vite 前端，Composition API 与响应式组合函数</p>
          </div>
          <div class="p-6 rounded-xl bg-card/50 border border-border/50 backdrop-blur-sm">
            <div class="text-2xl mb-2 font-bold text-foreground">Rust</div>
            <p class="text-sm text-muted-foreground">后端命令处理文件系统操作、下载与版本跟踪</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== FOOTER ========== -->
    <footer class="py-12 px-6 border-t border-border/30">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm text-muted-foreground mb-4">
          基于 Rito-w 的 <a href="https://github.com/Rito-w/skills-manager" target="_blank" rel="noopener" class="text-foreground font-medium hover:underline">skills-manager</a> 继续开发。感谢所有贡献者。
        </p>
        <div class="flex items-center justify-center gap-6 text-sm text-muted-foreground">
          <a href="https://github.com/qing-claw/qing-skill-manager" target="_blank" rel="noopener" class="hover:text-foreground transition-colors">GitHub</a>
          <span class="text-border">|</span>
          <span>MIT 许可证</span>
          <span class="text-border">|</span>
          <a href="https://github.com/qing-claw/qing-skill-manager/releases" target="_blank" rel="noopener" class="hover:text-foreground transition-colors">版本发布</a>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>
