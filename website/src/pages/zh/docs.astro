---
import BaseLayout from '@layouts/BaseLayout.astro'
import ThemeToggle from '@components/ThemeToggle.astro'
import LanguageSwitch from '@components/LanguageSwitch.astro'

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<BaseLayout
  title="使用文档 — Qing Skill Manager"
  description="Qing Skill Manager 完整使用指南：技能库、市场、IDE 浏览器、项目管理、版本控制。"
  lang="zh"
>
  <!-- NAV -->
  <nav class="sticky top-0 z-50 backdrop-blur-xl bg-background/70 border-b border-border/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <a href={`${BASE}/zh/`} class="flex items-center gap-2 font-semibold text-base sm:text-lg tracking-tight shrink-0">
        <img src={`${BASE}/favicon-32x32.png`} alt="" class="w-6 h-6 rounded" />
        <span class="hidden sm:inline">Qing Skill Manager</span>
        <span class="sm:hidden">QSM</span>
      </a>
      <div class="flex items-center gap-1.5 sm:gap-2">
        <a href={`${BASE}/zh/`} class="hidden sm:inline-block px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">首页</a>
        <a href={`${BASE}/zh/#download`} class="hidden sm:inline-block px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">下载</a>
        <LanguageSwitch lang="zh" />
        <ThemeToggle />
      </div>
    </div>
  </nav>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12 flex gap-8">
    <!-- SIDEBAR TOC -->
    <aside class="hidden lg:block w-56 shrink-0 sticky top-20 self-start max-h-[calc(100vh-6rem)] overflow-y-auto">
      <nav class="space-y-1 text-sm">
        <p class="font-semibold text-xs uppercase tracking-wider text-muted-foreground mb-3">使用文档</p>
        <a href="#overview" class="block py-1.5 text-muted-foreground hover:text-foreground transition-colors">概览</a>
        <a href="#skill-library" class="block py-1.5 text-muted-foreground hover:text-foreground transition-colors">技能库</a>
        <a href="#marketplace" class="block py-1.5 text-muted-foreground hover:text-foreground transition-colors">市场</a>
        <a href="#ide-browser" class="block py-1.5 text-muted-foreground hover:text-foreground transition-colors">IDE 浏览器</a>
        <a href="#projects" class="block py-1.5 text-muted-foreground hover:text-foreground transition-colors">项目管理</a>
        <a href="#versions" class="block py-1.5 text-muted-foreground hover:text-foreground transition-colors">版本管理</a>
        <a href="#conflicts" class="block py-1.5 text-muted-foreground hover:text-foreground transition-colors">冲突解决</a>
        <a href="#settings" class="block py-1.5 text-muted-foreground hover:text-foreground transition-colors">设置</a>
        <a href="#tips" class="block py-1.5 text-muted-foreground hover:text-foreground transition-colors">常见问题</a>
      </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="min-w-0 flex-1">
      <!-- Mobile TOC -->
      <details class="lg:hidden mb-8 rounded-xl border border-border/50 bg-card/50 overflow-hidden">
        <summary class="px-4 py-3 cursor-pointer font-semibold text-sm select-none">目录</summary>
        <nav class="px-4 pb-4 space-y-1 text-sm">
          <a href="#overview" class="block py-1 text-muted-foreground">概览</a>
          <a href="#skill-library" class="block py-1 text-muted-foreground">技能库</a>
          <a href="#marketplace" class="block py-1 text-muted-foreground">市场</a>
          <a href="#ide-browser" class="block py-1 text-muted-foreground">IDE 浏览器</a>
          <a href="#projects" class="block py-1 text-muted-foreground">项目管理</a>
          <a href="#versions" class="block py-1 text-muted-foreground">版本管理</a>
          <a href="#conflicts" class="block py-1 text-muted-foreground">冲突解决</a>
          <a href="#settings" class="block py-1 text-muted-foreground">设置</a>
          <a href="#tips" class="block py-1 text-muted-foreground">常见问题</a>
        </nav>
      </details>

      <div class="prose prose-neutral dark:prose-invert max-w-none
        [&_h1]:text-3xl [&_h1]:sm:text-4xl [&_h1]:font-bold [&_h1]:tracking-tight [&_h1]:mb-4
        [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:tracking-tight [&_h2]:mt-16 [&_h2]:mb-6 [&_h2]:pt-8 [&_h2]:border-t [&_h2]:border-border/50
        [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-[15px] [&_p]:leading-relaxed [&_p]:text-card-foreground [&_p]:mb-4
        [&_ul]:space-y-1.5 [&_ul]:mb-4 [&_li]:text-[15px] [&_li]:leading-relaxed
        [&_ol]:space-y-1.5 [&_ol]:mb-4 [&_ol_li]:text-[15px]
        [&_code]:text-sm [&_code]:bg-muted [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:font-mono
        [&_strong]:font-semibold
        [&_img]:rounded-xl [&_img]:border [&_img]:border-border/50 [&_img]:shadow-lg [&_img]:my-6
        [&_table]:text-sm [&_table]:w-full
        [&_th]:text-left [&_th]:px-3 [&_th]:py-2 [&_th]:font-semibold [&_th]:border-b [&_th]:border-border/50 [&_th]:bg-muted/50
        [&_td]:px-3 [&_td]:py-2 [&_td]:border-b [&_td]:border-border/30
        [&_blockquote]:border-l-4 [&_blockquote]:border-accent [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-muted-foreground
      ">

        <h1 id="overview">使用文档</h1>
        <p>Qing Skill Manager 帮助你在一个桌面应用中管理多个 Agent IDE 和项目中的 AI 技能。本文档涵盖所有功能。</p>

        <img src={`${BASE}/screenshots/zh-CN/local.jpg`} alt="技能库概览" />

        <h3>核心概念</h3>
        <ul>
          <li><strong>技能 (Skill)</strong> — AI Agent 扩展（包含 <code>SKILL.md</code> 和相关文件的目录），增强 IDE 的能力。</li>
          <li><strong>中央仓库</strong> — 所有技能统一存储在 <code>~/.qing-skill-manager/skills</code>，这是你的单一信息源。</li>
          <li><strong>安装 (Install)</strong> — 将技能从中央仓库复制到 IDE 的全局技能目录（所有项目可用）。</li>
          <li><strong>克隆到项目 (Clone)</strong> — 将特定版本的技能复制到项目的 IDE 目录（仅该项目可用）。</li>
          <li><strong>已托管 vs 未托管</strong> — 已托管的技能在仓库中被追踪。未托管的技能在 IDE 目录中找到但未被追踪——你可以将它们"收编"到仓库。</li>
        </ul>

        <h3>应用布局</h3>
        <p>应用顶部有五个主要标签页：</p>
        <table>
          <thead><tr><th>标签页</th><th>用途</th></tr></thead>
          <tbody>
            <tr><td><strong>Skill 库</strong></td><td>三栏工作台，浏览、查看和管理所有技能</td></tr>
            <tr><td><strong>Market</strong></td><td>从公共注册中心搜索和下载技能</td></tr>
            <tr><td><strong>IDE 浏览</strong></td><td>查看和管理各 IDE 中已安装的技能</td></tr>
            <tr><td><strong>项目管理</strong></td><td>注册项目、配置 IDE 目标、部署技能</td></tr>
            <tr><td><strong>设置</strong></td><td>主题、语言、默认版本策略</td></tr>
          </tbody>
        </table>

        <!-- ==================== 技能库 ==================== -->
        <h2 id="skill-library">技能库</h2>
        <p>技能库是主要工作台——三栏布局，管理你的全部技能收藏。</p>

        <img src={`${BASE}/screenshots/zh-CN/local.jpg`} alt="技能库三栏布局" />

        <h3>左侧边栏</h3>
        <ul>
          <li><strong>搜索</strong> — 按名称、描述或路径筛选技能。</li>
          <li><strong>平台筛选</strong> — 显示特定 IDE 的技能（全部、Claude Code、Cursor、Codex、OpenCode、OpenClaw）。</li>
          <li><strong>状态标签</strong> — 按 <code>已托管</code>（在仓库中）、<code>未托管</code>（在 IDE 中但不在仓库中）或 <code>仅插件</code> 筛选。</li>
          <li><strong>排序</strong> — 按名称、版本数或使用量排序。</li>
          <li><strong>多选</strong> — 勾选多个技能进行批量操作（安装、删除、收编）。</li>
        </ul>

        <h3>中间详情面板</h3>
        <p>选中技能后，中间面板显示：</p>
        <ul>
          <li>技能名称、描述和来源（来自哪个市场）。</li>
          <li>磁盘上的仓库路径。</li>
          <li><strong>全局安装</strong> — 哪些 IDE 全局安装了此技能，含版本和同步状态。</li>
          <li><strong>项目部署</strong> — 哪些项目使用此技能，含各项目版本和同步状态（已同步 / 已修改 / 冲突）。</li>
          <li>快捷操作按钮：<strong>安装到 IDE</strong>、<strong>打开目录</strong>、<strong>删除</strong>、<strong>从仓库移除</strong>。</li>
        </ul>

        <h3>右侧版本轨</h3>
        <p>最右栏显示选中技能的版本历史：</p>
        <ul>
          <li>所有版本按时间排列，<strong>默认版本</strong>有标记。</li>
          <li>每个版本显示：显示名称、创建日期、来源类型、IDE 数量、项目数量。</li>
          <li>每版本操作：<strong>重命名</strong>、<strong>删除</strong>、<strong>对比</strong>、<strong>设为默认</strong>。</li>
          <li><strong>注册版本</strong> — 将外部文件夹添加为此技能的新版本。</li>
        </ul>

        <h3>批量操作</h3>
        <p>使用侧边栏复选框选中多个技能，然后：</p>
        <ul>
          <li><strong>批量安装到 IDE</strong> — 一次性将所有选中技能安装到一个或多个 IDE。</li>
          <li><strong>删除选中</strong> — 从本地仓库中移除选中技能。</li>
          <li><strong>导入本地技能</strong> — 将包含 <code>SKILL.md</code> 的本地文件夹添加为新技能。</li>
        </ul>

        <!-- ==================== 市场 ==================== -->
        <h2 id="marketplace">市场</h2>
        <p>Market 标签页用于发现和下载公共注册中心的技能。</p>

        <img src={`${BASE}/screenshots/zh-CN/market.jpg`} alt="市场搜索" />

        <h3>搜索</h3>
        <p>在搜索框中输入关键词（名称、描述或作者），点击<strong>搜索</strong>。结果聚合自所有已启用的市场。</p>

        <h3>数据来源</h3>
        <table>
          <thead><tr><th>来源</th><th>地址</th><th>说明</th></tr></thead>
          <tbody>
            <tr><td>Claude Plugins</td><td><code>claude-plugins.dev</code></td><td>无需密钥</td></tr>
            <tr><td>SkillsLLM</td><td><code>skillsllm.com</code></td><td>无需密钥</td></tr>
            <tr><td>SkillsMP</td><td><code>skillsmp.com</code></td><td>可能需要 API 密钥</td></tr>
          </tbody>
        </table>

        <h3>下载与更新</h3>
        <ul>
          <li>点击技能卡片上的<strong>下载</strong>按钮将其添加到本地仓库。</li>
          <li>如果本地已存在该技能，按钮会显示<strong>更新</strong>。</li>
          <li>下载会排队进行——可以在下载状态区查看进度。</li>
          <li>下载的技能会立即出现在技能库标签页中。</li>
        </ul>

        <h3>市场设置</h3>
        <p>点击齿轮图标打开市场设置，可以：</p>
        <ul>
          <li>启用或禁用各个市场。</li>
          <li>配置 API 密钥（如 SkillsMP）。</li>
          <li>查看各数据源的连接状态。</li>
        </ul>

        <!-- ==================== IDE 浏览器 ==================== -->
        <h2 id="ide-browser">IDE 浏览器</h2>
        <p>IDE 浏览器显示系统中每个 IDE 的安装情况。</p>

        <img src={`${BASE}/screenshots/zh-CN/ide.jpg`} alt="IDE 浏览器" />

        <h3>切换 IDE</h3>
        <p>点击顶部的 IDE 标签切换查看。数量标记显示该 IDE 中有多少技能。</p>

        <h3>支持的 IDE</h3>
        <table>
          <thead><tr><th>IDE</th><th>全局路径</th><th>项目路径</th></tr></thead>
          <tbody>
            <tr><td>Claude Code</td><td><code>~/.claude/skills</code></td><td><code>.claude/skills</code></td></tr>
            <tr><td>Codex</td><td><code>~/.codex/skills</code></td><td><code>.codex/skills</code></td></tr>
            <tr><td>Cursor</td><td><code>~/.cursor/skills</code></td><td><code>.cursor/skills</code></td></tr>
            <tr><td>OpenClaw</td><td><code>~/.openclaw/skills</code></td><td><code>.openclaw/skills</code></td></tr>
            <tr><td>OpenCode</td><td><code>~/.config/opencode/skills</code></td><td><code>.opencode/skills</code></td></tr>
          </tbody>
        </table>

        <h3>技能操作</h3>
        <ul>
          <li><strong>打开目录</strong> — 在文件管理器中打开技能所在目录。</li>
          <li><strong>卸载</strong> — 从该 IDE 中移除技能（删除已复制的目录）。</li>
          <li><strong>纳入统一管理</strong> — 将未托管技能"收编"到中央仓库，进行版本追踪。</li>
        </ul>

        <h3>添加自定义 IDE</h3>
        <p>如果你的 IDE 不在列表中，点击<strong>添加 IDE</strong>。需要提供：</p>
        <ul>
          <li><strong>IDE 名称</strong> — 显示标签（如"Windsurf"）。</li>
          <li><strong>Skills 路径</strong> — 该 IDE 存储技能的相对或绝对路径（如 <code>.windsurf/skills</code>）。</li>
        </ul>
        <p>自定义 IDE 的功能和内置 IDE 完全一致——安装、卸载、管理技能都在同一界面。</p>

        <h3>技能分类</h3>
        <ul>
          <li><strong>托管副本</strong> — 从仓库安装的技能；被追踪和同步。</li>
          <li><strong>本地</strong> — 在 IDE 中找到但不在仓库中的技能（未托管）。</li>
          <li><strong>内置插件</strong> — IDE 自带的系统级插件（可通过复选框切换显示）。</li>
        </ul>

        <!-- ==================== 项目管理 ==================== -->
        <h2 id="projects">项目管理</h2>
        <p>项目标签页用于按项目管理技能部署。</p>

        <img src={`${BASE}/screenshots/zh-CN/project.jpg`} alt="项目管理" />

        <h3>添加项目</h3>
        <ol>
          <li>点击<strong>添加项目</strong>。</li>
          <li>用文件夹选择器选择项目目录。</li>
          <li>应用会自动检测项目使用的 IDE（通过查找 <code>.cursor</code>、<code>.claude</code> 等目录）。</li>
        </ol>

        <h3>配置 IDE 目标</h3>
        <p>点击项目上的<strong>配置</strong>按钮，选择该项目使用哪些 IDE。只有选中的 IDE 会在部署时接收技能。</p>

        <h3>部署技能</h3>
        <ul>
          <li>点击<strong>部署到项目</strong>，从技能库中选择技能并克隆到项目的 IDE 目录中。</li>
          <li>可以为每个技能选择部署的版本。</li>
          <li>应用会显示每个项目的<strong>已同步</strong>数量和<strong>总技能</strong>数量。</li>
        </ul>

        <h3>检测项目技能</h3>
        <p>点击<strong>检测项目 Skill</strong> 扫描项目目录，查看：</p>
        <ul>
          <li><strong>新增</strong> — 项目中有但仓库中没有的技能。</li>
          <li><strong>重复</strong> — 与仓库技能完全相同的副本。</li>
          <li><strong>已托管版本</strong> — 匹配仓库中某个特定版本。</li>
          <li><strong>冲突</strong> — 同名但内容与已知版本不同的技能。</li>
        </ul>

        <!-- ==================== 版本管理 ==================== -->
        <h2 id="versions">版本管理</h2>
        <p>每个技能可以有多个版本。通过技能库右侧版本轨或详情面板进入版本管理器。</p>

        <h3>版本属性</h3>
        <table>
          <thead><tr><th>属性</th><th>说明</th></tr></thead>
          <tbody>
            <tr><td>显示名称</td><td>人类可读的标签（如"v2 - 精简版"）</td></tr>
            <tr><td>版本号</td><td>语义化版本（如 1.0.0）</td></tr>
            <tr><td>内容哈希</td><td>技能内容的 SHA 哈希，用于检测变更</td></tr>
            <tr><td>来源</td><td>版本来自哪里：市场、项目、导入、克隆或迁移</td></tr>
            <tr><td>创建时间</td><td>版本注册的时间戳</td></tr>
          </tbody>
        </table>

        <h3>创建版本</h3>
        <ul>
          <li><strong>从文件夹</strong> — 指向包含更新技能文件的本地目录。</li>
          <li><strong>从项目</strong> — 从项目目录导入修改后的技能。</li>
          <li><strong>从市场</strong> — 下载更新时自动创建新版本。</li>
        </ul>

        <h3>对比版本</h3>
        <p>选择任意两个版本并点击<strong>对比</strong>，查看：</p>
        <ul>
          <li>文件级别的新增、删除和修改。</li>
          <li>元数据变更（名称、描述、作者）。</li>
          <li>相似度评分（百分比匹配）。</li>
        </ul>

        <h3>默认版本</h3>
        <p>每个技能有一个<strong>默认版本</strong>——安装到 IDE 时使用的版本。通过<strong>设为默认</strong>更改。</p>

        <h3>变体</h3>
        <p>变体是技能的命名分支，用于不同场景（如"详细版" vs "精简版"）。每个变体指向一个特定版本。在版本管理器中创建、重命名或删除变体。</p>

        <h3>删除策略</h3>
        <p>删除版本时可选择：</p>
        <ul>
          <li><strong>软删除</strong> — 标记为已删除，文件保留在磁盘上。</li>
          <li><strong>归档</strong> — 将文件移动到归档目录。</li>
          <li><strong>硬删除</strong> — 永久删除磁盘上的文件。</li>
        </ul>

        <!-- ==================== 冲突解决 ==================== -->
        <h2 id="conflicts">冲突解决</h2>
        <p>从项目导入技能时，如果仓库中已存在不同版本，应用会自动检测冲突。</p>

        <h3>冲突类型</h3>
        <table>
          <thead><tr><th>类型</th><th>含义</th></tr></thead>
          <tbody>
            <tr><td><strong>相同</strong></td><td>内容一致——无冲突。</td></tr>
            <tr><td><strong>补丁</strong></td><td>差异很小，可能是小幅更新。</td></tr>
            <tr><td><strong>小版本</strong></td><td>中等差异——部分文件有变更。</td></tr>
            <tr><td><strong>大版本</strong></td><td>大量文件有显著差异。</td></tr>
            <tr><td><strong>分叉</strong></td><td>内容大幅偏离——本质上是不同的技能。</td></tr>
          </tbody>
        </table>

        <h3>解决方案</h3>
        <ul>
          <li><strong>保留现有</strong> — 忽略导入的技能，保持当前版本不变。</li>
          <li><strong>覆盖</strong> — 用导入的版本替换现有技能。</li>
          <li><strong>共存（重命名）</strong> — 两者都保留——导入的技能获得新名称，避免冲突。</li>
        </ul>

        <h3>冲突分析</h3>
        <p>应用提供自动分析，包括：</p>
        <ul>
          <li>冲突严重程度（无 / 轻微 / 严重 / 破坏性）。</li>
          <li>是否可以自动解决。</li>
          <li>建议的解决方案及置信度评分。</li>
        </ul>

        <!-- ==================== 设置 ==================== -->
        <h2 id="settings">设置</h2>
        <h3>主题</h3>
        <p>选择<strong>浅色</strong>、<strong>深色</strong>或<strong>跟随系统</strong>。</p>

        <h3>语言</h3>
        <p>在<strong>英文</strong>和<strong>简体中文</strong>之间切换。即时生效，无需重启。</p>

        <h3>默认版本策略</h3>
        <p>控制安装技能到 IDE 时使用哪个版本：</p>
        <ul>
          <li><strong>手动</strong> — 每次都手动选择版本。</li>
          <li><strong>最新</strong> — 总是使用最新版本。</li>
          <li><strong>稳定</strong> — 使用指定的稳定版本。</li>
        </ul>

        <!-- ==================== 常见问题 ==================== -->
        <h2 id="tips">常见问题</h2>

        <h3>macOS 提示"应用已损坏"</h3>
        <p>应用尚未进行代码签名。在终端中运行：</p>
        <p><code>xattr -dr com.apple.quarantine "/Applications/qing-skill-manager.app"</code></p>

        <h3>技能存储在哪里？</h3>
        <p>中央仓库：<code>~/.qing-skill-manager/skills</code>。版本元数据：<code>~/.qing-skill-manager/versions</code>。</p>

        <h3>能管理未列出的 IDE 吗？</h3>
        <p>可以——进入 IDE 浏览器，点击<strong>添加 IDE</strong>，提供名称和技能存储路径即可。</p>

        <h3>如何将未托管的技能纳入仓库？</h3>
        <p>在 IDE 浏览器中，点击该技能的<strong>纳入统一管理</strong>按钮。这会将其复制到中央仓库，同时保留 IDE 中的原始文件。</p>

        <h3>能为特定项目锁定版本吗？</h3>
        <p>可以——部署到项目时选择要克隆的版本。项目会独立保持该版本，不受仓库后续更新影响。</p>

        <h3>从市场更新技能后会怎样？</h3>
        <p>仓库中会创建一个新版本。已有的安装和项目部署<strong>不会自动变更</strong>——由你决定何时更新各个位置。</p>

      </div>
